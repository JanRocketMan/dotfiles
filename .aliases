# Shared aliases — sourced by .zshrc (and .bashrc if desired)

# Claude: sandboxed by default, explicit opt-out
alias claude='claude-sandbox'
alias claude-unsafe='command claude --permission-mode plan'

# Editors
alias v='nvim'
alias vim='nvim -u ~/.config/nvim/lua/init.lua'

# ls
alias ll='ls -lah --color=auto'
alias la='ls -A --color=auto'
alias l='ls -CF --color=auto'

# jj (jujutsu) shortcuts
alias jl='jj log'
alias jd='jj diff'
alias js='jj status'

# tmux
alias ta='tmux a'
alias tn='tmux new'

# Python / debugging
alias dpython='python -m debugpy --wait-for-client --listen'
alias upi='uv pip install'
alias upu='uv pip uninstall'

# pcpctl
alias pcp='pcpctl'

# ripgrep
alias rg='rg --vimgrep'
alias ro='rg -uu --vimgrep'

# SSH tunnel helpers
# frp PORT — kill all SSH tunnels forwarding a given port
frp() {
    local pids
    pids=$(lsof -ti :"$1" -u "$USER" -a 2>/dev/null)
    if [[ -n "$pids" ]]; then
        echo "$pids" | xargs kill 2>/dev/null
        echo "Killed PIDs: $pids"
    fi
}
# fp PORT HOST — create SSH port forward
fp() { ssh -fN -L "$1":localhost:"$1" "$2"; }
