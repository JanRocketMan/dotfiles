{
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "WebSearch",
      "WebFetch",
      "mcp__gitlab-cli__*",
      "Edit(~/.claude/settings.json)",
      "Edit(~/.claude/settings.local.json)",
      "Edit(**/.claude/settings.json)",
      "Edit(**/.claude/settings.local.json)",
      "Bash(pre-commit *)",
      "Bash(chmod +x *)",
      "Bash(ruff *)",
      "Bash(uv *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(less *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(tree *)",
      "Bash(ls *)",
      "Bash(sed *)",
      "Bash(find *)",
      "Bash(stat *)",
      "Bash(du *)",
      "Bash(diff *)",
      "Bash(realpath *)",
      "Bash(readlink *)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(env *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(id)",
      "Bash(whoami)",
      "Bash(hostname)",
      "Bash(date *)",
      "Bash(uname *)",
      "Bash(printenv *)",
      "Bash(sort *)",
      "Bash(acli jira *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(awk *)",
      "Bash(xargs *)",
      "Bash(jq *)",
      "Bash(jj *)",
      "Bash(dvc pull *)",
      "Bash(yq *)",
      "Bash(shasum *)",
      "Bash(md5 *)",
      "Bash(df *)",
      "Bash(npx prettier *)",
      "Bash(glab *)",
      "Edit(//tmp/**)",
      "Write(//tmp/**)",
      "Write(~/.claude/settings.json)",
      "Write(~/.claude/settings.local.json)",
      "Write(**/.claude/settings.json)",
      "Write(**/.claude/settings.local.json)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(git *)"
    ],
    "ask": [
      "Bash(jj abandon)",
      "Bash(jj abandon *)",
      "Bash(jj absorb)",
      "Bash(jj absorb *)",
      "Bash(jj bookmark *)",
      "Bash(jj diffedit)",
      "Bash(jj diffedit *)",
      "Bash(jj git push)",
      "Bash(jj git push *)",
      "Bash(jj operation restore *)",
      "Bash(jj operation undo)",
      "Bash(jj operation undo *)",
      "Bash(jj op restore *)",
      "Bash(jj op undo)",
      "Bash(jj op undo *)",
      "Bash(jj parallelize)",
      "Bash(jj parallelize *)",
      "Bash(jj rebase)",
      "Bash(jj rebase *)",
      "Bash(jj resolve)",
      "Bash(jj resolve *)",
      "Bash(jj restore)",
      "Bash(jj restore *)",
      "Bash(jj revert)",
      "Bash(jj revert *)",
      "Bash(jj split)",
      "Bash(jj split *)",
      "Bash(jj squash)",
      "Bash(jj squash *)",
      "Bash(jj undo)",
      "Bash(jj undo *)",
      "Bash(glab issue close *)",
      "Bash(glab issue delete *)",
      "Bash(glab mr close *)",
      "Bash(glab mr delete *)",
      "Bash(glab mr merge *)",
      "Bash(glab repo delete *)",
      "Bash(glab release delete *)",
      "Bash(glab label delete *)"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "theme": "dark"
}
