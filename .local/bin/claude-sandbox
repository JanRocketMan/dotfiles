#!/usr/bin/env bash
set -euo pipefail

# claude-sandbox — Launch Claude Code inside a bubblewrap (bwrap) sandbox.
#
# Why:
#   Claude Code in auto mode has unrestricted shell access. On a shared
#   multi-tenant machine (e.g. a SLURM login node) this is risky: a misguided
#   tool call can read SSH private keys, leak .env secrets, corrupt other
#   users' projects, or rm -rf the wrong directory.
#
#   This wrapper uses Linux user namespaces (via bwrap) to confine Claude to
#   a minimal filesystem view: the target project is read-write, .venv and
#   system tools are read-only, .env files are masked, SSH keys are hidden
#   (only the agent socket is forwarded), and nothing outside the project
#   is reachable. No root privileges required.
#
# What it does:
#   - Mounts system dirs (/usr, /bin, /lib, /etc) read-only
#   - Creates an empty tmpfs $HOME, then selectively binds user tools (ro)
#   - Binds the project directory read-write, with .venv overlaid read-only
#   - Masks .env / .env.* files with /dev/null (except .example templates)
#   - Exposes SSH agent socket but hides private keys
#   - Forwards only a curated set of environment variables
#   - Launches Claude Code in auto permission mode by default
#
# Usage:
#   claude-sandbox [OPTIONS] [PROJECT_DIR] [-- CLAUDE_ARGS...]
#
#   PROJECT_DIR defaults to the current working directory if omitted.
#
# Auto-detection:
#   - GPU: if /dev/nvidiactl exists, NVIDIA devices are bind-mounted, /sys is
#     exposed read-only, /dev/shm is added, and CUDA/NCCL/TORCH env vars are
#     forwarded automatically.
#   - Proxy: if ~/.config/proxy-creds/credentials.json exists (and mitmdump +
#     combined CA are present), a credential-injection proxy starts automatically.
#     Generate credentials.json from env vars with: proxy-creds-gen
#
# Options:
#   --ro PATH      Extra read-only bind mount (repeatable)
#   --rw PATH      Extra read-write bind mount (repeatable)
#   --dry-run      Print the full bwrap command without executing
#   --shell        Launch /bin/bash instead of claude (useful for debugging)
#
# Examples:
#   claude-sandbox ~/myproject
#   claude-sandbox                              # uses $PWD
#   claude-sandbox --ro /cm/shared ~/myproject
#   claude-sandbox --dry-run ~/myproject
#   claude-sandbox ~/myproject -- --resume
#   claude-sandbox --shell ~/myproject -- -c 'ls ~/.ssh'
#
# Suggested aliases (add to ~/.bashrc or ~/.config/fish/config.fish):
#   bash:  alias cld='claude-sandbox'
#   fish:  alias cld 'claude-sandbox'

HOME_DIR="$HOME"
USER_NAME="$(whoami)"

# ── Argument parsing ──────────────────────────────────────────────────────────

PROJECT_DIR=""
EXTRA_RO=()
EXTRA_RW=()
DRY_RUN=0
USE_SHELL=0
CLAUDE_ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --ro)
            EXTRA_RO+=("$2")
            shift 2
            ;;
        --rw)
            EXTRA_RW+=("$2")
            shift 2
            ;;
        --dry-run)
            DRY_RUN=1
            shift
            ;;
        --shell)
            USE_SHELL=1
            shift
            ;;
        --)
            shift
            CLAUDE_ARGS=("$@")
            break
            ;;
        -*)
            echo "error: unknown flag: $1" >&2
            echo "usage: claude-sandbox [--ro PATH]... [--rw PATH]... [--dry-run] PROJECT_DIR [-- CLAUDE_ARGS...]" >&2
            exit 1
            ;;
        *)
            if [[ -z "$PROJECT_DIR" ]]; then
                PROJECT_DIR="$(realpath "$1")"
            else
                echo "error: unexpected argument: $1" >&2
                exit 1
            fi
            shift
            ;;
    esac
done

if [[ -z "$PROJECT_DIR" ]]; then
    PROJECT_DIR="$(realpath .)"
fi

if [[ ! -d "$PROJECT_DIR" ]]; then
    echo "error: $PROJECT_DIR is not a directory" >&2
    exit 1
fi

# ── ssh-agent setup ───────────────────────────────────────────────────────────

AGENT_DIR="/tmp/ssh-agent-${USER_NAME}"
AGENT_SOCK="${AGENT_DIR}/agent.sock"

ensure_ssh_agent() {
    # Check if we already have a working agent
    if [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
        if ssh-add -l &>/dev/null || [[ $? -eq 1 ]]; then
            # Agent is alive (exit 0 = keys listed, exit 1 = no keys but alive)
            return 0
        fi
    fi

    # Check the deterministic socket
    if [[ -S "$AGENT_SOCK" ]]; then
        export SSH_AUTH_SOCK="$AGENT_SOCK"
        if ssh-add -l &>/dev/null || [[ $? -eq 1 ]]; then
            return 0
        fi
    fi

    # Start a new agent
    mkdir -p "$AGENT_DIR"
    chmod 700 "$AGENT_DIR"
    rm -f "$AGENT_SOCK"
    eval "$(ssh-agent -a "$AGENT_SOCK" 2>/dev/null)"
    export SSH_AUTH_SOCK="$AGENT_SOCK"

    echo "Started ssh-agent (PID: $SSH_AGENT_PID)" >&2

    # Load keys referenced in ~/.ssh/config
    for key in "$HOME_DIR/.ssh/id_ed25519" "$HOME_DIR/.ssh/github_jan" "$HOME_DIR/.ssh/debug"; do
        if [[ -f "$key" ]]; then
            ssh-add "$key" 2>/dev/null && echo "  Loaded $key" >&2 || echo "  Failed to load $key" >&2
        fi
    done
}

ensure_ssh_agent

# ── Credential-injection proxy (auto-detected) ──────────────────────────────

PROXY_PORT=18080
PROXY_ADDR="127.0.0.1:${PROXY_PORT}"
PROXY_PID_FILE="/tmp/mitmdump-claude-sandbox.pid"
COMBINED_CA="$HOME_DIR/.mitmproxy/combined-ca.pem"
ADDON_SCRIPT="$HOME_DIR/.config/proxy-creds/inject_credentials.py"
CRED_MAPPING="$HOME_DIR/.config/proxy-creds/credentials.json"
PROXY_ENABLED=0

if [[ -f "$CRED_MAPPING" ]] && [[ -s "$CRED_MAPPING" ]]; then
    if ! command -v mitmdump &>/dev/null; then
        echo "warning: $CRED_MAPPING found but mitmdump not installed (uv tool install mitmproxy)" >&2
    elif [[ ! -f "$COMBINED_CA" ]]; then
        echo "warning: $CRED_MAPPING found but combined CA missing: $COMBINED_CA" >&2
    else
        PROXY_ENABLED=1
        # Start mitmdump if not already running
        if [[ -f "$PROXY_PID_FILE" ]] && kill -0 "$(cat "$PROXY_PID_FILE")" 2>/dev/null; then
            echo "Proxy already running (PID: $(cat "$PROXY_PID_FILE"))" >&2
        else
            mitmdump \
                --listen-host 127.0.0.1 \
                --listen-port "$PROXY_PORT" \
                --set confdir="$HOME_DIR/.mitmproxy" \
                -s "$ADDON_SCRIPT" \
                --quiet \
                &>/tmp/mitmdump-claude-sandbox.log &
            echo $! > "$PROXY_PID_FILE"
            echo "Started mitmdump proxy on $PROXY_ADDR (PID: $!)" >&2
            sleep 1
        fi
    fi
fi

# ── NSS fix for user-namespace sandboxes ─────────────────────────────────────
# On LDAP/SSSD machines the current user may not appear in /etc/passwd.
# Build a synthetic passwd + files-only nsswitch.conf so git/ssh can resolve
# the UID inside the sandbox.

SANDBOX_PASSWD=$(mktemp /tmp/claude-sandbox-passwd.XXXXXX)
SANDBOX_NSSWITCH=$(mktemp /tmp/claude-sandbox-nsswitch.XXXXXX)
trap 'rm -f "$SANDBOX_PASSWD" "$SANDBOX_NSSWITCH"' EXIT

cp /etc/passwd "$SANDBOX_PASSWD" 2>/dev/null || true
if ! grep -q "^${USER_NAME}:" "$SANDBOX_PASSWD" 2>/dev/null; then
    getent passwd "$USER_NAME" >> "$SANDBOX_PASSWD" 2>/dev/null
fi

# Force files-only lookups — LDAP/SSSD sockets aren't in the sandbox
cat > "$SANDBOX_NSSWITCH" <<'NSSEOF'
passwd:     files
group:      files
shadow:     files
hosts:      files dns
networks:   files
protocols:  files
services:   files
NSSEOF

# ── Build bwrap command ───────────────────────────────────────────────────────

BWRAP_ARGS=()

# Namespaces and lifecycle
BWRAP_ARGS+=(--unshare-all --share-net --die-with-parent)

# Virtual filesystems
BWRAP_ARGS+=(--proc /proc --dev /dev --tmpfs /tmp)

# System + user tools (read-only)
RO_DIRS=(
    /usr /lib /lib64 /bin /sbin /etc
    "$HOME_DIR/.local/bin"
    "$HOME_DIR/.local/gcc-11"
    "$HOME_DIR/.local/share/uv"
    "$HOME_DIR/.config/uv"
    "$HOME_DIR/.config/nvim"
    "$HOME_DIR/.config/jj"
    "$HOME_DIR/.config/glab-cli"
    "$HOME_DIR/ripgrep-14.1.0-x86_64-unknown-linux-musl"
    "$HOME_DIR/fd-v10.1.0-x86_64-unknown-linux-musl"
    "$HOME_DIR/nvim-linux64"
)

# Home as tmpfs (empty base, we selectively bind into it)
BWRAP_ARGS+=(--tmpfs "$HOME_DIR")

for dir in "${RO_DIRS[@]}"; do
    [[ -d "$dir" ]] && BWRAP_ARGS+=(--ro-bind "$dir" "$dir")
done

# Overlay synthetic passwd + nsswitch on top of /etc (must come after /etc bind)
BWRAP_ARGS+=(--ro-bind "$SANDBOX_PASSWD" /etc/passwd)
BWRAP_ARGS+=(--ro-bind "$SANDBOX_NSSWITCH" /etc/nsswitch.conf)

# /etc/resolv.conf is often a symlink into /run/systemd/resolve/ which isn't
# mounted in the sandbox. Ensure the symlink target path exists so DNS works.
RESOLV_REAL="$(readlink -f /etc/resolv.conf 2>/dev/null)"
if [[ -n "$RESOLV_REAL" && -f "$RESOLV_REAL" && "$RESOLV_REAL" != "/etc/resolv.conf" ]]; then
    parent="$(dirname "$RESOLV_REAL")"
    acc=""
    IFS='/' read -ra segs <<< "${parent#/}"
    for seg in "${segs[@]}"; do
        acc="$acc/$seg"
        BWRAP_ARGS+=(--dir "$acc")
    done
    BWRAP_ARGS+=(--ro-bind "$RESOLV_REAL" "$RESOLV_REAL")
fi

# jj is a single binary file, not a directory
if [[ -f "$HOME_DIR/jj" ]]; then
    BWRAP_ARGS+=(--ro-bind "$HOME_DIR/jj" "$HOME_DIR/jj")
fi

# Claude binary versions (read-write for auto-updates)
if [[ -d "$HOME_DIR/.local/share/claude" ]]; then
    BWRAP_ARGS+=(--bind "$HOME_DIR/.local/share/claude" "$HOME_DIR/.local/share/claude")
fi

# Claude config (read-write)
BWRAP_ARGS+=(--bind "$HOME_DIR/.claude" "$HOME_DIR/.claude")
if [[ -f "$HOME_DIR/.claude.json" ]]; then
    BWRAP_ARGS+=(--bind "$HOME_DIR/.claude.json" "$HOME_DIR/.claude.json")
fi

# Cache directory (read-write, persistent across sessions)
mkdir -p "$HOME_DIR/.cache"
BWRAP_ARGS+=(--bind "$HOME_DIR/.cache" "$HOME_DIR/.cache")

# SSH: config (ro) + known_hosts (rw) — NO private keys
# Copy ssh config to a temp file so ownership matches inside the user namespace
# (SSH rejects bind-mounted files with mismatched owner)
BWRAP_ARGS+=(--tmpfs "$HOME_DIR/.ssh")
if [[ -f "$HOME_DIR/.ssh/config" ]]; then
    SANDBOX_SSH_CONFIG=$(mktemp /tmp/claude-sandbox-sshcfg.XXXXXX)
    cp "$HOME_DIR/.ssh/config" "$SANDBOX_SSH_CONFIG"
    chmod 600 "$SANDBOX_SSH_CONFIG"
    trap 'rm -f "$SANDBOX_PASSWD" "$SANDBOX_NSSWITCH" "$SANDBOX_SSH_CONFIG"' EXIT
    BWRAP_ARGS+=(--ro-bind "$SANDBOX_SSH_CONFIG" "$HOME_DIR/.ssh/config")
fi
if [[ -f "$HOME_DIR/.ssh/known_hosts" ]]; then
    BWRAP_ARGS+=(--bind "$HOME_DIR/.ssh/known_hosts" "$HOME_DIR/.ssh/known_hosts")
fi

# SSH agent socket
if [[ -S "$SSH_AUTH_SOCK" ]]; then
    BWRAP_ARGS+=(--bind "$SSH_AUTH_SOCK" "$SSH_AUTH_SOCK")
fi

# Project directory (read-write)
BWRAP_ARGS+=(--bind "$PROJECT_DIR" "$PROJECT_DIR")

# .venv read-only overlay (if exists)
if [[ -d "$PROJECT_DIR/.venv" ]]; then
    BWRAP_ARGS+=(--ro-bind "$PROJECT_DIR/.venv" "$PROJECT_DIR/.venv")
fi

# Mask .env files with /dev/null (skip .example templates)
for envfile in "$PROJECT_DIR/.env" "$PROJECT_DIR"/.env.*; do
    if [[ -f "$envfile" ]] && [[ "$envfile" != *.example ]]; then
        BWRAP_ARGS+=(--ro-bind /dev/null "$envfile")
    fi
done

# Extra read-only binds
for path in "${EXTRA_RO[@]}"; do
    rpath="$(realpath "$path")"
    if [[ -e "$rpath" ]]; then
        BWRAP_ARGS+=(--ro-bind "$rpath" "$rpath")
    else
        echo "warning: --ro path does not exist: $path" >&2
    fi
done

# Extra read-write binds
for path in "${EXTRA_RW[@]}"; do
    rpath="$(realpath "$path")"
    if [[ -e "$rpath" ]]; then
        BWRAP_ARGS+=(--bind "$rpath" "$rpath")
    else
        echo "warning: --rw path does not exist: $path" >&2
    fi
done

# ── GPU passthrough (auto-detected) ──────────────────────────────────────────

GPU_DETECTED=0
if [[ -c /dev/nvidiactl ]]; then
    GPU_DETECTED=1

    # NVIDIA device nodes + DRI render nodes
    for dev in /dev/nvidia* /dev/dri/*; do
        [[ -e "$dev" ]] && BWRAP_ARGS+=(--dev-bind "$dev" "$dev")
    done

    # sysfs (GPU info, NUMA topology — read-only in user namespace anyway)
    [[ -d /sys ]] && BWRAP_ARGS+=(--ro-bind /sys /sys)

    # shared memory for PyTorch DataLoader multiprocessing
    BWRAP_ARGS+=(--tmpfs /dev/shm)
fi

# ── Environment ───────────────────────────────────────────────────────────────

SANDBOX_PATH="$HOME_DIR/.local/bin"
SANDBOX_PATH+=":$HOME_DIR/ripgrep-14.1.0-x86_64-unknown-linux-musl"
SANDBOX_PATH+=":$HOME_DIR/fd-v10.1.0-x86_64-unknown-linux-musl"
SANDBOX_PATH+=":$HOME_DIR/nvim-linux64/bin"
SANDBOX_PATH+=":$HOME_DIR/.local/gcc-11/bin"
SANDBOX_PATH+=":$HOME_DIR"
SANDBOX_PATH+=":/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

BWRAP_ARGS+=(--setenv CLAUDE_SANDBOX 1
             --setenv HOME "$HOME_DIR" --setenv USER "$USER_NAME"
             --setenv PATH "$SANDBOX_PATH" --setenv SHELL /bin/bash
             --setenv TORCHINDUCTOR_CACHE_DIR "$HOME_DIR/.cache/torch/inductor"
             --setenv TRITON_CACHE_DIR "$HOME_DIR/.cache/triton")

# Forward optional vars from parent if set
for var in TERM LANG LC_ALL ANTHROPIC_API_KEY CLAUDE_CODE_NO_FLICKER SSH_AUTH_SOCK GITLAB_REMOTE_PROJECT; do
    [[ -n "${!var:-}" ]] && BWRAP_ARGS+=(--setenv "$var" "${!var}")
done

# SSH: skip system config (/etc/ssh/ssh_config) — its included files fail
# ownership checks inside the user namespace (root UID is unmapped)
BWRAP_ARGS+=(--setenv GIT_SSH_COMMAND "ssh -F $HOME_DIR/.ssh/config")

# Forward jj identity so commits have proper authorship
JJ_USER="${JJ_USER:-$(jj config get user.name 2>/dev/null || true)}"
JJ_EMAIL="${JJ_EMAIL:-$(jj config get user.email 2>/dev/null || true)}"
[[ -n "$JJ_USER" ]]  && BWRAP_ARGS+=(--setenv JJ_USER "$JJ_USER")
[[ -n "$JJ_EMAIL" ]] && BWRAP_ARGS+=(--setenv JJ_EMAIL "$JJ_EMAIL")

# Forward CUDA / NCCL / PyTorch vars when GPU is detected
if [[ "$GPU_DETECTED" -eq 1 ]]; then
    while IFS='=' read -r var _; do
        case "$var" in
            CUDA_*|NCCL_*|TORCH_*|NVIDIA_*|CUDNN_*)
                BWRAP_ARGS+=(--setenv "$var" "${!var}")
                ;;
        esac
    done < <(env)
fi

# Proxy: inject CA cert + HTTP(S)_PROXY env vars
if [[ "$PROXY_ENABLED" -eq 1 ]]; then
    BWRAP_ARGS+=(--ro-bind "$COMBINED_CA" "$COMBINED_CA")
    BWRAP_ARGS+=(--setenv HTTP_PROXY "http://$PROXY_ADDR")
    BWRAP_ARGS+=(--setenv HTTPS_PROXY "http://$PROXY_ADDR")
    BWRAP_ARGS+=(--setenv SSL_CERT_FILE "$COMBINED_CA")
    BWRAP_ARGS+=(--setenv REQUESTS_CA_BUNDLE "$COMBINED_CA")
    BWRAP_ARGS+=(--setenv CURL_CA_BUNDLE "$COMBINED_CA")
    BWRAP_ARGS+=(--setenv NODE_EXTRA_CA_CERTS "$COMBINED_CA")
fi

# ── Launch ────────────────────────────────────────────────────────────────────

BWRAP_BIN="$(command -v bwrap)"

if [[ "$DRY_RUN" -eq 1 ]]; then
    if [[ "$USE_SHELL" -eq 1 ]]; then
        DRY_CMD="/bin/bash ${CLAUDE_ARGS[*]:-}"
    else
        DRY_CMD="claude --permission-mode auto ${CLAUDE_ARGS[*]:-}"
    fi
    echo "env -i $BWRAP_BIN \\"
    for arg in "${BWRAP_ARGS[@]}"; do
        printf '  %q \\\n' "$arg"
    done
    echo "  -- $DRY_CMD"
    exit 0
fi

cd "$PROJECT_DIR"
if [[ "$USE_SHELL" -eq 1 ]]; then
    exec env -i "$BWRAP_BIN" "${BWRAP_ARGS[@]}" -- /bin/bash "${CLAUDE_ARGS[@]}"
else
    exec env -i "$BWRAP_BIN" "${BWRAP_ARGS[@]}" -- claude --permission-mode auto "${CLAUDE_ARGS[@]}"
fi
